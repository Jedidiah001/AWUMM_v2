### Attendance Calculation

```typescript
function calculateAttendance(show: ShowDraft, universe: UniverseState): number {
  const baseAttendance = getBaseAttendance(show.type, show.brand);
  
  // Modifiers
  const cardQualityMod = calculateCardQuality(show.matches) * 0.3;
  const starPowerMod = calculateStarPower(show.matches) * 0.25;
  const brandPrestigeMod = getBrandPrestige(show.brand) * 0.15;
  const feudHeatMod = calculateFeudHeat(show.matches) * 0.15;
  const momentumMod = getPromotionMomentum(universe) * 0.1;
  const seasonalMod = getSeasonalModifier(universe.currentDate) * 0.05;
  
  const totalMod = 1 + cardQualityMod + starPowerMod + brandPrestigeMod + 
                   feudHeatMod + momentumMod + seasonalMod;
  
  const attendance = Math.floor(baseAttendance * totalMod);
  return clamp(attendance, 0, getVenueCapacity(show));
}

function getBaseAttendance(type: ShowType, brand: BrandId): number {
  const bases = {
    weekly: { alpha: 8000, velocity: 7000, vanguard: 3000 },
    ppv_minor: 12000,
    ppv_major: 18000,
    ple: 25000,
    victory_dome: 50000,
  };
  // Return appropriate base
}
```

### Revenue Calculation

```typescript
function calculateShowRevenue(show: ShowResult): ShowFinancials {
  const attendance = show.attendance;
  const ticketPrice = getTicketPrice(show.type);
  const grossTicketRevenue = attendance * ticketPrice;
  
  // Merch (percentage of attendance * average spend * star power factor)
  const merchSales = Math.floor(attendance * 0.4 * 15 * show.starPowerFactor);
  
  // PPV revenue (if applicable)
  const ppvBuyRate = show.isPpv ? calculatePPVBuyRate(show) : 0;
  const ppvRevenue = ppvBuyRate * getPPVPrice(show.tier);
  
  // Expenses
  const wrestlerPayroll = calculateShowPayroll(show);
  const productionCost = getProductionCost(show.type);
  const venueCost = getVenueCost(show.type, attendance);
  
  const netProfitLoss = grossTicketRevenue + merchSales + ppvRevenue - 
                        wrestlerPayroll - productionCost - venueCost;
  
  return {
    showId: show.id,
    attendance,
    maxCapacity: getVenueCapacity(show),
    ticketPrice,
    grossTicketRevenue,
    merchSales,
    productionCost,
    wrestlerPayroll,
    venueCost,
    netProfitLoss,
    ppvBuyRate: show.isPpv ? ppvBuyRate : undefined,
    ppvRevenue: show.isPpv ? ppvRevenue : undefined,
  };
}
```

