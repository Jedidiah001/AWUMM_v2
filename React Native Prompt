### Card Generation Algorithm

```typescript
function generateShowDraft(universe: UniverseState, showInfo: ScheduledShow): ShowDraft {
  const { brand, isPpv, ppvName, tier } = showInfo;
  const roster = getAvailableRoster(universe, brand);
  const activeFeud = getActiveFeuds(universe, brand);
  const titles = getBrandTitles(universe, brand);
  
  const matches: MatchDraft[] = [];
  const usedWrestlers = new Set<string>();
  
  // 1. MAIN EVENT
  const mainEvent = selectMainEvent(universe, showInfo, roster, activeFeuds, titles);
  matches.push(mainEvent);
  addUsedWrestlers(usedWrestlers, mainEvent);
  
  // 2. TITLE MATCHES (non-main event)
  const titleMatches = selectTitleMatches(universe, showInfo, roster, titles, usedWrestlers);
  matches.push(...titleMatches);
  titleMatches.forEach(m => addUsedWrestlers(usedWrestlers, m));
  
  // 3. FEUD MATCHES
  const feudMatches = selectFeudMatches(universe, showInfo, activeFeuds, usedWrestlers);
  matches.push(...feudMatches);
  feudMatches.forEach(m => addUsedWrestlers(usedWrestlers, m));
  
  // 4. FEATURED MATCHES (rising stars, call-up showcases)
  const featuredMatches = selectFeaturedMatches(universe, showInfo, roster, usedWrestlers);
  matches.push(...featuredMatches);
  featuredMatches.forEach(m => addUsedWrestlers(usedWrestlers, m));
  
  // 5. FILLER MATCHES (remaining roster, avoid staleness)
  const fillerMatches = selectFillerMatches(universe, showInfo, roster, usedWrestlers);
  matches.push(...fillerMatches);
  
  // 6. SEGMENTS (promos, backstage, etc.)
  const segments = generateSegments(universe, showInfo, activeFeuds);
  
  // 7. Sort by card position
  sortByCardPosition(matches);
  
  return {
    id: generateId(),
    showInfo,
    matches,
    segments,
    estimatedRating: calculateEstimatedRating(matches),
    estimatedAttendance: calculateEstimatedAttendance(matches, showInfo),
    notes: generateBookingNotes(matches),
    warnings: generateBookingWarnings(matches, universe),
  };
}
