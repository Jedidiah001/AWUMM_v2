function ContractNegotiationScreen({ route }: Props) {
  const { freeAgentId } = route.params;
  const freeAgent = useFreeAgent(freeAgentId);
  const [offer, setOffer] = useState<ContractOffer>(getDefaultOffer(freeAgent));
  const [negotiationState, setNegotiationState] = useState<NegotiationState>('initial');
  const [counterOffer, setCounterOffer] = useState<ContractOffer | null>(null);
  const [messages, setMessages] = useState<NegotiationMessage[]>([]);
  
  const { submitOffer, acceptCounter, walkAway } = useNegotiation(freeAgentId);
  
  const handleSubmitOffer = async () => {
    const result = await submitOffer(offer);
    setMessages([...messages, { type: 'player_offer', offer, timestamp: Date.now() }]);
    
    if (result.status === 'accepted') {
      setNegotiationState('accepted');
      // Navigate to success screen after delay
    } else if (result.status === 'counter') {
      setCounterOffer(result.counterOffer);
      setNegotiationState('counter_received');
      setMessages([...messages, { type: 'counter', offer: result.counterOffer, message: result.message }]);
    } else if (result.status === 'walked_away') {
      setNegotiationState('failed');
    } else {
      setNegotiationState('rejected');
      setMessages([...messages, { type: 'rejection', message: result.message }]);
    }
  };
  
  const handleAcceptCounter = async () => {
    await acceptCounter(counterOffer!);
    setNegotiationState('accepted');
