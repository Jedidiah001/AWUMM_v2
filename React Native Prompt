### Save Manager Store

```typescript
// src/store/saveManagerStore.ts
import { create } from 'zustand';
import { MMKV } from 'react-native-mmkv';

const storage = new MMKV();

interface SaveSlot {
  id: string;
  name: string;
  savedAt: number;
  year: number;
  week: number;
  balance: number;
  promotionName: string;
}

interface SaveManagerState {
  saveSlots: SaveSlot[];
  currentSlot: string | null;
}

interface SaveManagerActions {
  loadSaveSlots: () => void;
  createNewSave: (name: string) => string;
  deleteSave: (slotId: string) => void;
  renameSave: (slotId: string, newName: string) => void;
  setCurrentSlot: (slotId: string) => void;
}

export const useSaveManagerStore = create<SaveManagerState & SaveManagerActions>((set, get) => ({
  saveSlots: [],
  currentSlot: null,
  
  loadSaveSlots: () => {
    const keys = storage.getAllKeys();
    const saveKeys = keys.filter((k) => k.startsWith('save_') && k.endsWith('_meta'));
    
    const slots: SaveSlot[] = saveKeys.map((key) => {
      const slotId = key.replace('save_', '').replace('_meta', '');
      const meta = JSON.parse(storage.getString(key) || '{}');
      return {
        id: slotId,
        name: meta.name || slotId,
        savedAt: meta.savedAt || 0,
        year: meta.year || 1,
        week: meta.week || 1,
        balance: meta.balance || 0,
        promotionName: meta.promotionName || 'Ring of Champions',
      };
    }).sort((a, b) => b.savedAt - a.savedAt);
    
    set({ saveSlots: slots });
  },
  
  createNewSave: (name) => {
    const slotId = `slot_${Date.now()}`;
    const meta: SaveSlot = {
      id: slotId,
      name,
      savedAt: Date.now(),
      year: 1,
      week: 1,
      balance: 5000000,
      promotionName: 'Ring of Champions',
    };
    
    storage.set(`save_${slotId}_meta`, JSON.stringify(meta));
    
    set((state) => ({
      saveSlots: [meta, ...state.saveSlots],
      currentSlot: slotId,
    }));
    
    return slotId;
  },
  
  deleteSave: (slotId) => {
    storage.delete(`save_${slotId}`);
    storage.delete(`save_${slotId}_meta`);
    
    set((state) => ({
      saveSlots: state.saveSlots.filter((s) => s.id !== slotId),
      currentSlot: state.currentSlot === slotId ? null : state.currentSlot,
    }));
  },
  
  renameSave: (slotId, newName) => {
    const metaKey = `save_${slotId}_meta`;
    const meta = JSON.parse(storage.getString(metaKey) || '{}');
    meta.name = newName;
    storage.set(metaKey, JSON.stringify(meta));
    
    set((state) => ({
      saveSlots: state.saveSlots.map((s) =>
        s.id === slotId ? { ...s, name: newName } : s
      ),
    }));
  },
  
  setCurrentSlot: (slotId) => {
    set({ currentSlot: slotId });
  },
}));
