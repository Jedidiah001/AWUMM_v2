### Match Quality Calculation

```typescript
function calculateMatchQuality(
  sideA: SideRating,
  sideB: SideRating,
  matchDraft: MatchDraft
): number {
  // Base quality from wrestler skills
  const avgWorkRate = (sideA.workRate + sideB.workRate) / 2;
  const avgPsychology = (sideA.psychology + sideB.psychology) / 2;
  const avgSelling = (sideA.selling + sideB.selling) / 2;
  
  const baseQuality = (avgWorkRate * 0.4) + (avgPsychology * 0.35) + (avgSelling * 0.25);
  
  // Modifiers
  const chemistryMod = calculateChemistry(sideA, sideB) * 0.15;
  const staminaMod = ((sideA.stamina + sideB.stamina) / 200 - 0.5) * 0.1;
  const fatiguePenalty = ((sideA.fatigue + sideB.fatigue) / 200) * -0.15;
  const feudBonus = matchDraft.feudId ? 0.1 : 0;
  const titleBonus = matchDraft.titleId ? 0.08 : 0;
  const importanceBonus = getImportanceBonus(matchDraft.importance);
  const cardPositionBonus = getCardPositionBonus(matchDraft.cardPosition);
  const crowdHeatMod = ((sideA.popularity + sideB.popularity) / 200 - 0.5) * 0.1;
  
  // Random variance (±10%)
  const variance = (Math.random() - 0.5) * 0.2;
  
  const totalQuality = baseQuality * (1 + chemistryMod + staminaMod + fatiguePenalty + 
                                       feudBonus + titleBonus + importanceBonus + 
                                       cardPositionBonus + crowdHeatMod + variance);
  
  return clamp(totalQuality, 0, 100);
}

function qualityToStarRating(quality: number): number {
  // 0-100 quality to 0-5 stars (with precision to 0.25)
  const raw = (quality / 100) * 5;
  return Math.round(raw * 4) / 4;
}
```

### Winner Determination

```typescript
function determineWinner(
  sideA: ModifiedSideRating,
  sideB: ModifiedSideRating,
  bias: BookingBias
): 'A' | 'B' | 'draw' {
  // Base win probability from ratings
  const ratingDiff = sideA.overall - sideB.overall;
  let baseWinProbA = 0.5 + (ratingDiff / 200); // ±25% swing based on rating
  
  // Apply booking bias
  const biasModifiers = {
    'strong_a': 0.35,
    'slight_a': 0.15,
    'even': 0,
    'slight_b': -0.15,
    'strong_b': -0.35,
  };
  
  baseWinProbA += biasModifiers[bias];
  baseWinProbA = clamp(baseWinProbA, 0.05, 0.95);
  
  // Roll
  const roll = Math.random();
  if (roll < baseWinProbA) return 'A';
  return 'B';
}
```

### Upset Detection

```typescript
function checkForUpset(
  matchDraft: MatchDraft,
  winner: 'A' | 'B',
  universe: UniverseState
): UpsetEvent | null {
  const winnerIds = winner === 'A' ? matchDraft.participantAIds : matchDraft.participantBIds;
  const loserIds = winner === 'A' ? matchDraft.participantBIds : matchDraft.participantAIds;
  
  const winnerPopularity = getAveragePopularity(winnerIds, universe);
  const loserPopularity = getAveragePopularity(loserIds, universe);
  const winnerRole = getHighestRole(winnerIds, universe);
  const loserRole = getHighestRole(loserIds, universe);
  
  const popularityGap = loserPopularity - winnerPopularity;
  const roleGap = getRoleGap(loserRole, winnerRole);
  
  // Major upset: Jobber beats Main Eventer, or 30+ popularity gap
  if (roleGap >= 3 || popularityGap >= 30) {
    return {
      type: 'major_upset',
      winnerId: winnerIds[0],
      loserId: loserIds[0],
      popularityGap,
      roleGap,
      description: `MAJOR UPSET: ${getWrestlerName(winnerIds[0])} defeats ${getWrestlerName(loserIds[0])}!`,
    };
  }
  
  // Minor upset: Significant but not shocking
  if (roleGap >= 2 || popularityGap >= 20) {
    return {
      type: 'minor_upset',
      winnerId: winnerIds[0],
      loserId: loserIds[0],
      popularityGap,
      roleGap,
      description: `Upset victory for ${getWrestlerName(winnerIds[0])}!`,
    };
  }
  
  return null;
}
