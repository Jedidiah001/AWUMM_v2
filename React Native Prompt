## 13. Calendar System

```typescript
interface GameCalendar {
  currentYear: number;
  currentWeek: number; // 1-52
  currentShowIndex: number;
  scheduledShows: ScheduledShow[];
  completedShows: string[]; // Show IDs
}

interface ScheduledShow {
  id: string;
  year: number;
  week: number;
  dayOfWeek: 'monday' | 'friday' | 'saturday' | 'sunday';
  brand: BrandId | 'cross-brand';
  showType: 'weekly' | 'ppv' | 'ple' | 'special';
  name: string;
  isPpv: boolean;
  ppvName?: string;
  ppvTier?: 'minor' | 'major';
  venue?: string;
  isCompleted: boolean;
}

function generateYearCalendar(year: number): ScheduledShow[] {
  const shows: ScheduledShow[] = [];
  let showId = 0;
  
  for (let week = 1; week <= 52; week++) {
    // Check for PPV this week
    const ppvThisWeek = PPV_SCHEDULE.find(p => p.weekOfYear === week);
    
    if (ppvThisWeek) {
      // Add PPV (typically Sunday)
      shows.push({
        id: `${year}-${++showId}`,
        year,
        week,
        dayOfWeek: 'sunday',
        brand: ppvThisWeek.isCrossBrand ? 'cross-brand' : ppvThisWeek.focusBrand!,
        showType: ppvThisWeek.tier === 'major' ? 'ple' : 'ppv',
        name: ppvThisWeek.name,
        isPpv: true,
        ppvName: ppvThisWeek.name,
        ppvTier: ppvThisWeek.tier,
        isCompleted: false,
      });
    }
    
    // Weekly shows (always, unless PPV replaces them)
    if (!ppvThisWeek || !ppvThisWeek.replacesWeeklyShows) {
      // Monday - Alpha
      shows.push({
        id: `${year}-${++showId}`,
        year,
        week,
        dayOfWeek: 'monday',
        brand: 'alpha',
        showType: 'weekly',
        name: 'ROC Alpha',
        isPpv: false,
        isCompleted: false,
      });
      
      // Friday - Velocity
      shows.push({
        id: `${year}-${++showId}`,
        year,
        week,
        dayOfWeek: 'friday',
        brand: 'velocity',
        showType: 'weekly',
        name: 'ROC Velocity',
        isPpv: false,
        isCompleted: false,
      });
      
      // Saturday - Vanguard
      shows.push({
        id: `${year}-${++showId}`,
        year,
        week,
        dayOfWeek: 'saturday',
        brand: 'vanguard',
        showType: 'weekly',
        name: 'ROC Vanguard',
        isPpv: false,
        isCompleted: false,
      });
    }
  }
  
  return shows.sort((a, b) => {
    if (a.week !== b.week) return a.week - b.week;
    return getDayOrder(a.dayOfWeek) - getDayOrder(b.dayOfWeek);
  });
}

function getNextShow(calendar: GameCalendar): ScheduledShow {
  return calendar.scheduledShows.find(s => !s.isCompleted)!;
}

function advanceToNextShow(calendar: GameCalendar): GameCalendar {
  const nextShow = getNextShow(calendar);
  const updatedShows = calendar.scheduledShows.map(s =>
    s.id === nextShow.id ? { ...s, isCompleted: true } : s
  );
  
  // Generate next year if needed
  if (updatedShows.every(s => s.isCompleted)) {
    const nextYearShows = generateYearCalendar(calendar.currentYear + 1);
    return {
      currentYear: calendar.currentYear + 1,
      currentWeek: 1,
      currentShowIndex: 0,
      scheduledShows: nextYearShows,
      completedShows: [...calendar.completedShows, ...updatedShows.map(s => s.id)],
    };
  }
  
  const newNextShow = updatedShows.find(s => !s.isCompleted)!;
  return {
    ...calendar,
    currentWeek: newNextShow.week,
    currentShowIndex: calendar.currentShowIndex + 1,
    scheduledShows: updatedShows,
    completedShows: [...calendar.completedShows, nextShow.id],
  };
}
