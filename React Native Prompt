  titleShotDeadlineWeeks?: number;
  noJobClause: string[];
  merchSplit: number;
}

function generateFreeAgent(): FreeAgent {
  const age = randomInt(21, 38);
  const experience = Math.max(0, age - 18 - randomInt(0, 3));
  
  const wrestler = generateWrestler({
    age,
    experience,
    role: weightedRandom(['jobber', 'lower_midcard', 'midcard', 'upper_midcard', 'main_event'], [0.3, 0.3, 0.25, 0.1, 0.05]),
    popularity: randomInt(10, 60),
  });
  
  const demandedSalary = calculateDemandedSalary(wrestler);
  const demandedLength = randomInt(26, 104);
  
  return {
    wrestler,
    source: 'generated',
    availableSince: getCurrentDate(),
    demandedSalary,
    demandedLength,
    specialDemands: generateSpecialDemands(wrestler),
    interestLevel: randomInt(30, 100),
    competingOffers: [],
  };
}

function processNegotiation(
  negotiation: ContractNegotiation,
  universe: UniverseState
): NegotiationResult {
  const freeAgent = getFreeAgent(negotiation.freeAgentId, universe);
  
  // Calculate how good our offer is vs their demands
  const offerScore = scoreOffer(negotiation.rocOffer, freeAgent);
  const demandScore = scoreDemands(freeAgent);
  const satisfaction = offerScore / demandScore;
  
  // Factor in competing offers
  const competingPressure = freeAgent.competingOffers.length > 0 ? 0.9 : 1.0;
  const interestMod = freeAgent.interestLevel / 100;
  
  const acceptanceProbability = satisfaction * competingPressure * interestMod;
  
  if (acceptanceProbability >= 0.8) {
    return { status: 'accepted', message: `${freeAgent.wrestler.name} has signed with ROC!` };
  } else if (acceptanceProbability >= 0.5) {
    const counter = generateCounterOffer(freeAgent, negotiation.rocOffer);
    return { status: 'counter', counterOffer: counter, message: `${freeAgent.wrestler.name} has made a counter-offer.` };
  } else if (acceptanceProbability >= 0.3) {
    return { status: 'rejected', message: `${freeAgent.wrestler.name} has rejected the offer but remains in talks.` };
  } else {
    return { status: 'walked_away', message: `${freeAgent.wrestler.name} has ended negotiations.` };
  }
}
