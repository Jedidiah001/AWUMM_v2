function checkSurpriseReturn(
  showDraft: ShowDraft,
  universe: UniverseState
): SurpriseReturnEvent | null {
  // Only at major PPVs
  if (!showDraft.showInfo.isPpv) return null;
  
  const majorPPVs = ['Rumble Royale', 'Victory Dome', 'Summer Slamfest', 'Night of Glory'];
  if (!majorPPVs.includes(showDraft.showInfo.ppvName || '')) return null;
  
  // Check retired pool for eligible returners
  const eligibleReturners = universe.retiredWrestlers.filter(w => 
    w.isMajorSuperstar &&
    w.age < 55 &&
    weeksSinceRetirement(w, universe) >= 26 && // At least 6 months retired
    !w.permanentlyRetired
  );
  
  if (eligibleReturners.length === 0) return null;
  
  // Probability based on PPV importance
  const baseProbability = showDraft.showInfo.ppvName === 'Victory Dome' ? 0.5 : 0.25;
  
  if (Math.random() > baseProbability) return null;
  
  // Select returner
  const returner = selectBestReturner(eligibleReturners, universe);
  
  return {
    type: 'surprise_return',
    wrestlerId: returner.id,
    wrestlerName: returner.name,
    showId: showDraft.id,
    description: `SHOCKING RETURN: ${returner.name} HAS RETURNED!`,
    popularityBoost: 25,
    momentumBoost: 50,
    crowdReaction: 'thunderous',
  };
