### Post-Show Effect Processing

```typescript
function processPostShowEffects(
  showDraft: ShowDraft,
  matchResults: MatchResult[],
  universe: UniverseState
): UniverseState {
  let updated = deepClone(universe);
  
  // Update wrestler stats
  for (const result of matchResults) {
    for (const change of result.statChanges) {
      updated = applyWrestlerStatChange(change, updated);
    }
    for (const injury of result.injuries) {
      updated = applyInjury(injury, updated);
    }
  }
  
  // Update feud intensities
  for (const result of matchResults) {
    if (result.matchDraft.feudId) {
      updated = updateFeudIntensity(result, updated);
    }
  }
  
  // Check for new feuds from upsets
  const upsets = matchResults.flatMap(r => r.specialEvents.filter(e => e.type.includes('upset')));
  for (const upset of upsets) {
    if (Math.random() < 0.4) { // 40% chance upset spawns feud
      updated = createFeudFromUpset(upset, updated);
    }
  }
  
  // Reset weekly fatigue (partial)
  updated = resetPartialFatigue(updated, showDraft.showInfo.brand);
  
  // Process retirements
  const retirementCandidates = checkRetirementCandidates(updated);
  for (const candidate of retirementCandidates) {
    if (shouldRetire(candidate, updated)) {
      updated = processRetirement(candidate, updated);
    }
  }
  
  return updated;
}
