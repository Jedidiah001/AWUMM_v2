### Store Structure

```typescript
// src/store/universeStore.ts
import { create } from 'zustand';
import { persist, createJSONStorage } from 'zustand/middleware';
import { MMKV } from 'react-native-mmkv';

const storage = new MMKV();

const mmkvStorage = {
  getItem: (name: string) => {
    const value = storage.getString(name);
    return value ?? null;
  },
  setItem: (name: string, value: string) => {
    storage.set(name, value);
  },
  removeItem: (name: string) => {
    storage.delete(name);
  },
};

interface UniverseState {
  // Core data
  universe: Universe;
  
  // Current session
  currentShowDraft: ShowDraft | null;
  lastShowResult: ShowResult | null;
  
  // UI state
  isLoading: boolean;
  error: string | null;
}

interface UniverseActions {
  // Initialization
  initializeNewUniverse: (config?: UniverseConfig) => void;
  loadUniverse: (saveSlot: string) => Promise<void>;
  saveUniverse: (saveSlot?: string) => Promise<void>;
  
  // Game flow
  generateShowDraft: () => Promise<ShowDraft>;
  updateShowDraft: (updates: Partial<ShowDraft>) => void;
  updateMatchDraft: (matchId: string, updates: Partial<MatchDraft>) => void;
  simulateShow: () => Promise<ShowResult>;
  advanceToNextShow: () => void;
  
  // Roster management
  hireWrestler: (wrestlerId: string, contract: ContractOffer) => void;
  releaseWrestler: (wrestlerId: string) => void;
  extendContract: (wrestlerId: string, newContract: ContractOffer) => void;
  changeBrand: (wrestlerId: string, newBrand: BrandId) => void;
  changeAlignment: (wrestlerId: string, newAlignment: Alignment) => void;
  changeRole: (wrestlerId: string, newRole: Role) => void;
  retireWrestler: (wrestlerId: string, withTour?: boolean) => void;
  
  // Tag teams & factions
  createTagTeam: (memberIds: [string, string], name: string) => void;
  disbandTagTeam: (tagTeamId: string) => void;
  createFaction: (name: string, leaderId: string, memberIds: string[]) => void;
  addToFaction: (factionId: string, wrestlerId: string) => void;
  removeFromFaction: (factionId: string, wrestlerId: string) => void;
  disbandFaction: (factionId: string) => void;
  
  // Storylines
  createFeud: (type: FeudType, participantIds: string[], titleId?: string) => void;
  updateFeud: (feudId: string, updates: Partial<Feud>) => void;
  resolveFeud: (feudId: string, winnerId: string, resolutionType: ResolutionType) => void;
  
  // Championships
  vacateTitle: (titleId: string) => void;
  awardTitle: (titleId: string, newHolderId: string) => void;
  
  // Create-a-Wrestler
  createWrestler: (wrestler: Partial<Wrestler>) => void;
  
  // Year One scripting
  triggerScriptedEvent: (eventId: string) => void;
}

export const useUniverseStore = create<UniverseState & UniverseActions>()(
  persist(
    (set, get) => ({
      // Initial state
      universe: createDefaultUniverse(),
      currentShowDraft: null,
      lastShowResult: null,
      isLoading: false,
      error: null,
      
      // Initialization
      initializeNewUniverse: (config) => {
        const newUniverse = createUniverse(config);
        set({ universe: newUniverse, currentShowDraft: null, lastShowResult: null });
      },
      
      loadUniverse: async (saveSlot) => {
        set({ isLoading: true, error: null });
        try {
          const savedData = storage.getString(`save_${saveSlot}`);
          if (!savedData) throw new Error('Save not found');
          const universe = JSON.parse(savedData) as Universe;
          set({ universe, isLoading: false });
        } catch (error) {
          set({ error: (error as Error).message, isLoading: false });
        }
      },
      
      saveUniverse: async (saveSlot = 'autosave') => {
        const { universe } = get();
        storage.set(`save_${saveSlot}`, JSON.stringify(universe));
        storage.set(`save_${saveSlot}_meta`, JSON.stringify({
          savedAt: Date.now(),
          year: universe.calendar.currentYear,
          week: universe.calendar.currentWeek,
          balance: universe.finances.balance,
        }));
      },
      
      // Game flow
      generateShowDraft: async () => {
        const { universe } = get();
        const nextShow = getNextShow(universe.calendar);
        const draft = creativeDirector.generateShowDraft(universe, nextShow);
        set({ currentShowDraft: draft });
        return draft;
      },
      
      updateShowDraft: (updates) => {
        set((state) => ({
          currentShowDraft: state.currentShowDraft 
            ? { ...state.currentShowDraft, ...updates }
            : null,
        }));
      },
      
      updateMatchDraft: (matchId, updates) => {
        set((state) => ({
          currentShowDraft: state.currentShowDraft ? {
            ...state.currentShowDraft,
            matches: state.currentShowDraft.matches.map((m) =>
              m.id === matchId ? { ...m, ...updates } : m
            ),
          } : null,
        }));
      },
      
      simulateShow: async () => {
        const { universe, currentShowDraft } = get();
        if (!currentShowDraft) throw new Error('No show draft');
        
        set({ isLoading: true });
        
        const { showResult, updatedUniverse } = simulateShow(currentShowDraft, universe);
        
        set({
          universe: updatedUniverse,
          lastShowResult: showResult,
          currentShowDraft: null,
          isLoading: false,
        });
        
        // Auto-save after each show
        get().saveUniverse();
        
        return showResult;
      },
      
      advanceToNextShow: () => {
        set((state) => ({
          universe: {
            ...state.universe,
            calendar: advanceCalendar(state.universe.calendar),
          },
          lastShowResult: null,
        }));
      },
      
      // Roster management
      hireWrestler: (wrestlerId, contract) => {
        set((state) => {
          const freeAgent = state.universe.freeAgentPool.availableFreeAgents
            .find((fa) => fa.wrestler.id === wrestlerId);
          if (!freeAgent) return state;
          
          const wrestler: Wrestler = {
            ...freeAgent.wrestler,
            status: 'active',
            contract: createContract(contract, state.universe.calendar.currentDate),
            primaryBrand: contract.brandAssignment,
          };
          
          return {
            universe: {
              ...state.universe,
              wrestlers: [...state.universe.wrestlers, wrestler],
              freeAgentPool: {
                ...state.universe.freeAgentPool,
                availableFreeAgents: state.universe.freeAgentPool.availableFreeAgents
                  .filter((fa) => fa.wrestler.id !== wrestlerId),
              },
            },
          };
        });
      },
      
      releaseWrestler: (wrestlerId) => {
        set((state) => {
          const wrestler = state.universe.wrestlers.find((w) => w.id === wrestlerId);
          if (!wrestler) return state;
          
          const releasedWrestler: Wrestler = {
            ...wrestler,
            status: 'released',
          };
          
          const freeAgent: FreeAgent = {
            wrestler: releasedWrestler,
            source: 'released',
            availableSince: state.universe.calendar.currentDate,
            demandedSalary: wrestler.contract.salaryPerShow * 0.8,
            demandedLength: 52,
            specialDemands: [],
            interestLevel: 50,
            competingOffers: [],
          };
          
          return {
            universe: {
              ...state.universe,
              wrestlers: state.universe.wrestlers.filter((w) => w.id !== wrestlerId),
              freeAgentPool: {
                ...state.universe.freeAgentPool,
                recentReleases: [freeAgent, ...state.universe.freeAgentPool.recentReleases],
              },
            },
          };
        });
      },
      
      // ... additional actions
      
    }),
    {
      name: 'awum-universe',
      storage: createJSONStorage(() => mmkvStorage),
      partialize: (state) => ({
        universe: state.universe,
      }),
    }
  )
);

