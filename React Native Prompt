## 15. Morale & Locker Room System

```typescript
interface LockerRoom {
  overallMorale: number; // -100 to 100
  harmony: number; // 0-100
  cliques: Clique[];
  leaders: string[]; // Wrestler IDs with locker room influence
  recentIncidents: LockerRoomIncident[];
}

interface Clique {
  id: string;
  name: string;
  leaderIds: string[];
  memberIds: string[];
  alignment: 'positive' | 'negative' | 'neutral';
  influence: number; // 0-100
}

interface LockerRoomIncident {
  id: string;
  type: 'fight' | 'complaint' | 'walkout' | 'political_play' | 'mentoring' | 'party' | 'prank';
  involvedWrestlerIds: string[];
  description: string;
  moraleImpact: number;
  harmonyImpact: number;
  occurredAt: GameDate;
}

function updateMorale(wrestler: Wrestler, events: MoraleEvent[]): Wrestler {
  let moraleChange = 0;
  
  for (const event of events) {
    switch (event.type) {
      case 'win':
        moraleChange += 5;
        break;
      case 'loss':
        moraleChange -= 3;
        break;
      case 'title_win':
        moraleChange += 20;
        break;
      case 'title_loss':
        moraleChange -= 15;
        break;
      case 'ppv_main_event':
        moraleChange += 10;
        break;
      case 'not_booked':
        moraleChange -= 5;
        break;
      case 'jobbed_out':
        moraleChange -= 10;
        break;
      case 'pushed':
        moraleChange += 8;
        break;
      case 'creative_disagreement':
        moraleChange -= 12;
        break;
      case 'contract_extension':
        moraleChange += 15;
        break;
      case 'passed_over_for_title':
        moraleChange -= 8;
        break;
    }
  }
  
  // Apply traits
  if (wrestler.traits.includes('professional')) {
    moraleChange = Math.floor(moraleChange * 0.6);
  } else if (wrestler.traits.includes('drama_queen')) {
    moraleChange = Math.floor(moraleChange * 1.5);
  }
  
  const newMorale = clamp(wrestler.morale + moraleChange, -100, 100);
  
  return { ...wrestler, morale: newMorale };
}

function checkMoraleConsequences(wrestler: Wrestler, universe: UniverseState): MoraleConsequence[] {
  const consequences: MoraleConsequence[] = [];
  
  if (wrestler.morale <= -80) {
    // Very unhappy - might demand release
    if (Math.random() < 0.2) {
      consequences.push({ type: 'release_request', severity: 'high' });
    }
    // Might leak to dirt sheets
    if (Math.random() < 0.3) {
      consequences.push({ type: 'dirt_sheet_leak', severity: 'medium' });
    }
  } else if (wrestler.morale <= -50) {
    // Unhappy - reduced performance
    consequences.push({ type: 'reduced_performance', severity: 'low', performanceMod: -10 });
    // Might complain publicly
    if (Math.random() < 0.15) {
      consequences.push({ type: 'social_media_complaint', severity: 'medium' });
    }
  }
  
  // Very happy wrestlers
  if (wrestler.morale >= 80) {
    consequences.push({ type: 'performance_boost', severity: 'positive', performanceMod: 5 });
    if (wrestler.traits.includes('locker_room_leader')) {
      consequences.push({ type: 'morale_spread', severity: 'positive', spreadMod: 3 });
    }
  }
  
  return consequences;
}
