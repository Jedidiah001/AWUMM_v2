## 11. Show Simulation Engine

```typescript
function simulateShow(
  showDraft: ShowDraft,
  universe: UniverseState
): { showResult: ShowResult; updatedUniverse: UniverseState } {
  let currentUniverse = deepClone(universe);
  const matchResults: MatchResult[] = [];
  const segmentResults: SegmentResult[] = [];
  const showEvents: ShowEvent[] = [];
  
  // Pre-show processing
  const surpriseReturn = checkSurpriseReturn(showDraft, currentUniverse);
  if (surpriseReturn) {
    currentUniverse = processSurpriseReturn(surpriseReturn, currentUniverse);
    showEvents.push(surpriseReturn);
  }
  
  // Process each card item in order
  for (const item of showDraft.cardOrder) {
    if (item.type === 'match') {
      const matchDraft = showDraft.matches.find(m => m.id === item.id)!;
      const matchResult = simulateMatch(matchDraft, currentUniverse);
      matchResults.push(matchResult);
      
      // Apply match effects to universe
      currentUniverse = applyMatchEffects(matchResult, currentUniverse);
      
      // Check for title change
      if (matchDraft.titleId && matchResult.winner) {
        const titleChange = processTitleChange(matchDraft, matchResult, currentUniverse);
        if (titleChange) {
          showEvents.push(titleChange);
          currentUniverse = applyTitleChange(titleChange, currentUniverse);
        }
      }
      
      // Add any match events
      showEvents.push(...matchResult.specialEvents);
      
    } else if (item.type === 'segment') {
      const segmentDraft = showDraft.segments.find(s => s.id === item.id)!;
      const segmentResult = simulateSegment(segmentDraft, currentUniverse);
      segmentResults.push(segmentResult);
      currentUniverse = applySegmentEffects(segmentResult, currentUniverse);
    }
  }
  
  // Post-show processing
  currentUniverse = processPostShowEffects(showDraft, matchResults, currentUniverse);
  
  // Calculate show financials
  const financials = calculateShowFinancials(showDraft, matchResults, currentUniverse);
  currentUniverse = applyFinancials(financials, currentUniverse);
  
  // Calculate show ratings
  const ratings = calculateShowRatings(matchResults, segmentResults, showDraft);
  
  // Age/contract progression (if end of week)
  if (isEndOfWeek(showDraft.showInfo)) {
    currentUniverse = processWeekEnd(currentUniverse);
  }
  
  // Year-end processing
  if (isEndOfYear(showDraft.showInfo)) {
    currentUniverse = processYearEnd(currentUniverse);
  }
  
  const showResult: ShowResult = {
    id: showDraft.id,
    showInfo: showDraft.showInfo,
    matchResults,
    segmentResults,
    showEvents,
    financials,
    ratings,
    overallRating: calculateOverallShowRating(matchResults),
    fanSatisfaction: calculateFanSatisfaction(matchResults, showEvents, currentUniverse),
  };
  
  // Log show to history
  currentUniverse = logShowToHistory(showResult, currentUniverse);
  
  return { showResult, updatedUniverse: currentUniverse };
}
