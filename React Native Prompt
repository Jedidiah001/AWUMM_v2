### Match Simulation Flow

```typescript
function simulateMatch(
  matchDraft: MatchDraft,
  universe: UniverseState
): MatchResult {
  // 1. Calculate base ratings for each side
  const sideA = calculateSideRating(matchDraft.participantAIds, universe);
  const sideB = calculateSideRating(matchDraft.participantBIds, universe);
  
  // 2. Apply modifiers
  const modifiedA = applyMatchModifiers(sideA, matchDraft, universe);
  const modifiedB = applyMatchModifiers(sideB, matchDraft, universe);
  
  // 3. Determine winner
  const winner = determineWinner(modifiedA, modifiedB, matchDraft.bookingBias);
  
  // 4. Calculate match quality
  const matchQuality = calculateMatchQuality(sideA, sideB, matchDraft);
  
  // 5. Generate match narrative
  const narrative = generateMatchNarrative(matchDraft, winner, matchQuality, universe);
  
  // 6. Check for special events
  const specialEvents = checkSpecialEvents(matchDraft, winner, universe);
  
  // 7. Calculate stat changes
  const statChanges = calculateStatChanges(matchDraft, winner, matchQuality, specialEvents);
  
  // 8. Check for injuries
  const injuries = checkInjuries(matchDraft, universe);
  
  return {
    matchId: matchDraft.id,
    matchDraft,
    winner,
    loser: winner === 'A' ? 'B' : 'A',
    matchQuality,
    starRating: qualityToStarRating(matchQuality),
    duration: calculateDuration(matchDraft, matchQuality),
    finishType: determineFinishType(matchDraft, winner, universe),
    narrative,
    specialEvents,
    statChanges,
    injuries,
    crowdReaction: calculateCrowdReaction(matchDraft, winner, matchQuality),
  };
}
